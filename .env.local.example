# Firebase 웹앱 설정 (console.firebase.google.com → 프로젝트 설정 → 웹앱)
# 이 파일을 복사해서 .env.local 로 만들고 실제 값을 채우세요.
# Vercel 배포 시에는 같은 키들을 Vercel 프로젝트 환경변수에 등록합니다.

NEXT_PUBLIC_FB_API_KEY=
NEXT_PUBLIC_FB_AUTH_DOMAIN=
NEXT_PUBLIC_FB_PROJECT_ID=
NEXT_PUBLIC_FB_STORAGE_BUCKET=
NEXT_PUBLIC_FB_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FB_APP_ID=

# 조회 매칭용 서버 시크릿(향후 해시 매칭에 사용 — 지금은 미사용)
# MATCH_PEPPER=
