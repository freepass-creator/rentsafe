# 착한거래 환경변수 — 이 파일을 복사해 .env.local 로 만들고 값을 채우세요 (.env.local 커밋 금지)
# Vercel 배포 시 같은 키들을 Vercel 프로젝트 환경변수에 등록합니다.

# ── Firebase (착한거래 전용 프로젝트 권장) ──
# Firebase 콘솔 → 프로젝트 설정 → 일반 → 내 앱(웹앱)
NEXT_PUBLIC_FB_API_KEY=
NEXT_PUBLIC_FB_AUTH_DOMAIN=
NEXT_PUBLIC_FB_PROJECT_ID=
NEXT_PUBLIC_FB_STORAGE_BUCKET=
NEXT_PUBLIC_FB_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FB_APP_ID=

# ── Gemini OCR (신분증·사업자등록증 자동인식) ──
# https://aistudio.google.com/apikey 에서 발급. 서버 전용(NEXT_PUBLIC 아님).
GEMINI_API_KEY=
